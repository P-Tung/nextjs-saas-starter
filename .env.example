# ============================================
# SITE CONFIGURATION (Required)
# ============================================
# Your app name - appears in metadata, emails, and UI
NEXT_PUBLIC_APP_NAME="SaaS Template"

# Canonical production domain for metadata, sitemap, and robots
# Vercel deployment URLs are used as fallback when this is not set
# Format: https://yourdomain.com (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Support email for contact forms and legal pages
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"

# Public GitHub template repository URL for marketing CTAs
# Format: https://github.com/your-org/your-repo
NEXT_PUBLIC_GITHUB_REPO_URL=""

# ============================================
# FIREBASE (Optional - for auth, database, analytics)
# ============================================
# Get these from Firebase Console > Project Settings > General
# Leave empty to run without Firebase (demo mode)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Analytics / GA4 measurement ID (optional)
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# Google OAuth Client ID (optional, for Google sign-in)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Google Search Console verification token (optional)
GOOGLE_SITE_VERIFICATION=""

# ============================================
# HOSTED CMS (Optional - for CMS-ready content)
# ============================================
# Leave empty to render local fallback config from src/config.
# These values let the template fetch hosted landing blocks and collections.
NEXT_PUBLIC_CMS_PROJECT_ID=""
CMS_API_URL=""
CMS_API_KEY=""

# ============================================
# FIREBASE ADMIN (Server-side only)
# ============================================
# Service account JSON for server-side Firebase operations
# Get from Firebase Console > Project Settings > Service Accounts
# Store the entire JSON object as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Storage bucket for server-side file operations
FIREBASE_STORAGE_BUCKET=""

# ============================================
# POLAR (Optional - for payments/billing)
# ============================================
# Get these from Polar dashboard
# Leave empty to run without billing features
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""

# Product IDs from Polar dashboard.
# These map to the template, hosted CMS, and self-hosted CMS offers.
NEXT_PUBLIC_POLAR_PRODUCT_LITE_TEMPLATE=""
NEXT_PUBLIC_POLAR_PRODUCT_HOSTED_CMS=""
NEXT_PUBLIC_POLAR_PRODUCT_SELF_HOSTED_CMS=""

# ============================================
# BREVO (Optional - for transactional emails)
# ============================================
# Server-side only. Used for signup and waitlist emails.
BREVO_API_KEY=""
BREVO_SENDER_EMAIL=""
BREVO_SENDER_NAME=""
BREVO_REPLY_TO_EMAIL=""
